generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HomeSectionKey {
  HERO
  LATEST_WRITING
  TRAVEL
  SELECTED_WORK
}

enum HomeSectionSourceCollection {
  BLOG_AND_NOTES
  TRAVEL
  PROJECTS
}

enum HomeSectionItemKind {
  HERO_STAT
  PINNED_ENTRY
  LINK
}

enum ContentCollection {
  BLOG
  TRAVEL
  NOTES
  PROJECTS
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions  Session[]
  accounts  Account[]
  adminUser AdminUser?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                   String   @id @default(cuid())
  accountId            String
  providerId           String
  userId               String
  accessToken          String?  @db.Text
  refreshToken         String?  @db.Text
  idToken              String?  @db.Text
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model AdminUser {
  id        String   @id @default(cuid())
  userId    String   @unique
  isOwner   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_users")
}

model SiteSettings {
  id          String   @id @default(cuid())
  siteName    String
  role        String
  location    String
  title       String
  description String   @db.Text
  url         String
  email       String
  intro       String   @db.Text
  status      String   @db.Text
  locale      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  navItems    NavItem[]
  socialLinks SocialLink[]

  @@map("site_settings")
}

model NavItem {
  id             String       @id @default(cuid())
  siteSettingsId String
  href           String
  label          String
  isVisible      Boolean      @default(true)
  sortOrder      Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  siteSettings SiteSettings @relation(fields: [siteSettingsId], references: [id], onDelete: Cascade)

  @@unique([siteSettingsId, href])
  @@unique([siteSettingsId, sortOrder])
  @@map("nav_items")
}

model SocialLink {
  id             String       @id @default(cuid())
  siteSettingsId String
  href           String
  label          String
  isVisible      Boolean      @default(true)
  sortOrder      Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  siteSettings SiteSettings @relation(fields: [siteSettingsId], references: [id], onDelete: Cascade)

  @@unique([siteSettingsId, href])
  @@unique([siteSettingsId, sortOrder])
  @@map("social_links")
}

model HomeSection {
  id               String                     @id @default(cuid())
  key              HomeSectionKey             @unique
  eyebrow          String?
  title            String
  description      String?                    @db.Text
  isVisible        Boolean                    @default(true)
  sortOrder        Int
  sourceCollection HomeSectionSourceCollection?
  maxItems         Int?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  items HomeSectionItem[]

  @@map("home_sections")
}

model HomeSectionItem {
  id              String             @id @default(cuid())
  homeSectionId   String
  sortOrder       Int
  kind            HomeSectionItemKind
  label           String?
  value           String?
  href            String?
  contentCollection ContentCollection?
  slug            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  homeSection HomeSection @relation(fields: [homeSectionId], references: [id], onDelete: Cascade)

  @@unique([homeSectionId, sortOrder])
  @@map("home_section_items")
}

model AboutPage {
  id               String   @id @default(cuid())
  eyebrow          String
  title            String   @db.Text
  description      String   @db.Text
  profileHeading   String
  profileBody      String[]
  profileBodySecondary String[]
  focusHeading     String
  focusBody        String   @db.Text
  principlesHeading String
  principles       Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("about_page")
}
